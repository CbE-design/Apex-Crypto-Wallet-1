
/**
 * @fileoverview Firestore Security Rules for Apex Crypto Wallet.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for all data, except for admins
 * who have broader read access for management purposes.
 *
 * Data Structure:
 * The data is organized hierarchically under the `users/{userId}` collection.
 *
 * Key Security Decisions:
 * - All data is private and accessible only to the owning user, or an admin.
 * - User listing is permitted for admins to facilitate user management.
 * - Data consistency is enforced using relational integrity checks where applicable.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Admin status is determined by matching the connected wallet address
      // with the one defined in the environment variables.
      // We read the user's own document to get their wallet address.
      let adminWalletAddress = firestore.get_param("NEXT_PUBLIC_ADMIN_WALLET_ADDRESS", "");
      let userWalletAddress = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.walletAddress;
      return isSignedIn() && userWalletAddress == adminWalletAddress;
    }
    
    /**
     * @description Enforces ownership for user profiles, but allows admins to read.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow create: if isSignedIn()
                   && isOwner(userId)
                   && request.resource.data.id == userId;
      // A user can get their own document, or an admin can get any document.
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn()
                    && isOwner(userId)
                    && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isOwner(userId);
      // Only admins can list all users.
      allow list: if isSignedIn() && isAdmin();
    }

    /**
     * @description Enforces user-ownership for cryptocurrency wallets.
     * @path /users/{userId}/wallets/{walletId}
     */
    match /users/{userId}/wallets/{walletId} {
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow get, list: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn()
                    && isOwner(userId)
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Enforces user-ownership for transaction history within a wallet.
     * @path /users/{userId}/wallets/{walletId}/transactions/{transactionId}
     */
    match /users/{userId}/wallets/{walletId}/transactions/{transactionId} {
      allow create, get, update, delete, list: if isSignedIn() && isOwner(userId);
    }

     /**
      * @description Enforces user-ownership for price alerts.
      * @path /users/{userId}/price_alerts/{priceAlertId}
      */
    match /users/{userId}/price_alerts/{priceAlertId} {
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow get, list: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn()
                    && isOwner(userId)
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isOwner(userId);
    }
  }
}
