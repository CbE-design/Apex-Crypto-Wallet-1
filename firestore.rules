rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@apexwallet.io' ||
        request.auth.token.email == 'corrie@apex-crypto.co.uk'
      );
    }

    /**
     * @description Global Protocol Settings
     */
    match /protocol_settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Withdrawal Requests - Users can create, Admins can update status
     */
    match /withdrawal_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    /**
     * @description KYC Submissions - Users can create/read their own, Admins can update
     */
    match /kyc_submissions/{submissionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    /**
     * @description Admin Notifications - Only admins can read/write
     */
    match /admin_notifications/{notificationId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Hierarchical rules for user-specific data.
     * Admins can list and read all users; users can only read/write their own.
     */
    match /users/{userId} {
      allow list: if isAdmin();
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Collection Group Rules for Background Ledger Verification.
     */
    match /{path=**}/wallets/{walletId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{path=**}/transactions/{transactionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
