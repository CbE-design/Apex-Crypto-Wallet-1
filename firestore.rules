rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin check — token-based (more secure) or fallback to specific UIDs
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email == 'admin@apexwallet.io' ||
        request.auth.token.email == 'corrie@apex-crypto.co.uk' ||
        request.auth.token.email == 'apex@test.com' ||
        request.auth.uid == 'xTqwKRdxUnQnsNe4n7bQAHmh3lC3'
      );
    }

    // ─── Protocol Settings ─────────────────────────────────────────────────────
    match /protocol_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Withdrawal Requests ───────────────────────────────────────────────────
    match /withdrawal_requests/{requestId} {
      allow list:   if isAdmin();
      allow get:    if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── KYC Submissions ──────────────────────────────────────────────────────
    match /kyc_submissions/{submissionId} {
      allow list:   if isAdmin();
      allow get:    if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── Admin Notifications ──────────────────────────────────────────────────
    match /admin_notifications/{notificationId} {
      allow read, write: if isAdmin();
    }

    // ─── Collection Group Rules ───────────────────────────────────────────────
    // Required for searching wallets across all users in the Fund Wallet page
    match /{path=**}/wallets/{walletId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /{path=**}/transactions/{transactionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
    
    // ─── User Profiles ────────────────────────────────────────────────────────
    match /users/{userId} {
      allow list:  if isAdmin();
      allow get:   if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();

      match /wallets/{walletId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      match /{allSubcollections=**} {
        allow read:  if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // ─── Platform Configuration ───────────────────────────────────────────────
    match /platform_config/{docId} {
      allow read, write: if isAdmin();
    }

    // ─── Prices / Market Data ─────────────────────────────────────────────────
    match /prices/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Email Logs / Notification Logs ───────────────────────────────────────
    match /email_logs/{docId} {
      allow read, write: if isAdmin();
    }

    match /notification_logs/{docId} {
      allow read, write: if isAdmin();
    }

  }
}