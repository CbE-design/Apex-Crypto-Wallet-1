
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    /**
     * @description Public read access for wallets and transactions.
     * This supports Collection Group queries for the Apex Explorer and 
     * provides a transparent ledger experience.
     */
    match /{path=**}/wallets/{walletId} {
      allow read: if true;
    }

    match /{path=**}/transactions/{transactionId} {
      allow read: if true;
    }

    /**
     * @description Hierarchical rules for user-specific data.
     */
    match /users/{userId} {
      allow read: if true; // Allow lookup by walletAddress
      allow write: if isOwner(userId);

      match /wallets/{walletId} {
        allow read: if true;
        allow write: if isOwner(userId);

        match /transactions/{transactionId} {
          allow read: if true;
          allow write: if isOwner(userId);
        }
      }

      match /price_alerts/{alertId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
