
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.uid == "eHo0ensfcbVB1ApTwAITiXug6sp2";
    }
    
    /**
     * @description Collection Group rules for Explorer queries.
     */
    match /{path=**}/wallets/{walletId} {
      allow list: if true;
      allow get: if true;
    }

    match /{path=**}/transactions/{transactionId} {
      allow list: if true;
      allow get: if true;
    }

    /**
     * @description Enforces ownership for user profiles.
     */
    match /users/{userId} {
      allow create: if isSignedIn() && isOwner(userId);
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn()
                    && isOwner(userId)
                    && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allow anyone to query the users collection to find a user by wallet address.
     */
    match /users {
        allow list: if true;
    }

    /**
     * @description Wallets subcollection rules.
     */
    match /users/{userId}/wallets/{walletId} {
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow get, list: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if (isSignedIn() && isOwner(userId) && request.resource.data.userId == resource.data.userId) || (isSignedIn() && isAdmin());
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Transactions subcollection rules.
     */
    match /users/{userId}/wallets/{walletId}/transactions/{transactionId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow write: if (isSignedIn() && isOwner(userId)) || (isSignedIn() && isAdmin());
    }

    /**
     * @description Price Alerts rules.
     */
    match /users/{userId}/price_alerts/{priceAlertId} {
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow get, list: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn()
                    && isOwner(userId)
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isOwner(userId);
    }
  }
}
