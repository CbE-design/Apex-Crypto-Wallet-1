
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    /**
     * @description Collection Group Rules for Explorer.
     * We allow global read access to wallets and transactions to simulate a public ledger.
     * This is required for cross-user address verification in the Apex Explorer.
     */
    match /{path=**}/wallets/{walletId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{path=**}/transactions/{transactionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Hierarchical rules for user-specific data.
     */
    match /users/{userId} {
      allow read: if true; 
      allow write: if isOwner(userId);

      match /wallets/{walletId} {
        allow read: if true;
        allow write: if isOwner(userId);

        match /transactions/{transactionId} {
          allow read: if true;
          allow write: if isOwner(userId);
        }
      }

      match /price_alerts/{alertId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
