
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * @description Global Protocol Settings
     * Authorized orchestration permits public reads for network transparency.
     * Writes are restricted to authenticated administrative identities.
     */
    match /protocol_settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Hierarchical rules for user-specific data.
     * Whitelists recursive subcollection access for the verified document owner.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Collection Group Rules for Background Ledger Verification.
     * Permits wide-scale reconciliation across the private identity rails.
     */
    match /{path=**}/wallets/{walletId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{path=**}/transactions/{transactionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
