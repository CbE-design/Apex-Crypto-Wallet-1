
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.uid == "eHo0ensfcbVB1ApTwAITiXug6sp2";
    }
    
    /**
     * @description Collection Group rules for Explorer queries and public identity verification.
     * We allow public read access to wallets and transactions to simulate a transparent public ledger.
     */
    match /{path=**}/wallets/{walletId} {
      allow get, list: if true;
    }

    match /{path=**}/transactions/{transactionId} {
      allow get, list: if true;
    }

    /**
     * @description Enforces ownership for user profiles.
     */
    match /users/{userId} {
      allow create: if isSignedIn() && isOwner(userId);
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if true; // Allowed to find users by walletAddress (QAP)
      allow update: if isSignedIn()
                    && isOwner(userId)
                    && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Subcollection rules for personal data management.
     */
    match /users/{userId}/wallets/{walletId} {
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if (isSignedIn() && isOwner(userId)) || isAdmin();
      allow delete: if isSignedIn() && isOwner(userId);
    }

    match /users/{userId}/wallets/{walletId}/transactions/{transactionId} {
      allow write: if (isSignedIn() && isOwner(userId)) || isAdmin();
    }

    match /users/{userId}/price_alerts/{priceAlertId} {
      allow create: if isSignedIn() && isOwner(userId);
      allow get, list: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }
  }
}
