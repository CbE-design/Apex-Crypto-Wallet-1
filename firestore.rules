
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    /**
     * @description Global Protocol Settings - Publicly readable for status monitoring
     */
    match /protocol_settings/{document} {
      allow read: if true;
      allow write: if isSignedIn(); // Restricted to Admin UID in production
    }

    /**
     * @description Hierarchical rules for user-specific data.
     */
    match /users/{userId} {
      // Explicitly allow owners to read and write their own profile
      allow read, write: if isOwner(userId);

      match /wallets/{walletId} {
        allow read, write: if isOwner(userId);

        match /transactions/{transactionId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /price_alerts/{alertId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Collection Group Rules for Explorer and Admin Verification.
     */
    match /{path=**}/wallets/{walletId} {
      allow read: if true;
    }

    match /{path=**}/transactions/{transactionId} {
      allow read: if true;
    }
  }
}
