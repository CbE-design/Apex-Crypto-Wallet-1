
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Global Protocol Settings - Publicly readable for status monitoring
     */
    match /protocol_settings/{document} {
      allow read: if true;
      allow write: if isSignedIn(); // Restricted to Admin UID in production
    }

    /**
     * @description Hierarchical rules for user-specific data.
     * Owners have full read/write access to their profile and all subcollections.
     */
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    /**
     * @description Collection Group Rules for Explorer and Admin Verification.
     * Explicitly allows public read access for block explorer functionality.
     */
    match /{path=**}/wallets/{walletId} {
      allow read: if true;
    }

    match /{path=**}/transactions/{transactionId} {
      allow read: if true;
    }
  }
}
