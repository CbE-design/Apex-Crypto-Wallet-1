rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin check — email-based, no wallet required.
    // Add additional admin emails to this list as needed.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@apexwallet.io' ||
        request.auth.token.email == 'corrie@apex-crypto.co.uk'
      );
    }

    // ─── Protocol Settings ─────────────────────────────────────────────────────
    // Global platform on/off switch. Anyone can read (needed for maintenance
    // mode banner shown to unauthenticated users). Only admins may write.
    match /protocol_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Withdrawal Requests ───────────────────────────────────────────────────
    // Users may create a request for themselves and read their own requests.
    // Admins can list all, read any, and update status (approve/reject).
    // No user may update or delete their own requests once submitted.
    match /withdrawal_requests/{requestId} {
      allow list:   if isAdmin();
      allow get:    if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── KYC Submissions ──────────────────────────────────────────────────────
    // Users may submit once and read their own submission.
    // Admins can list all, read any, and update status (approve/reject).
    match /kyc_submissions/{submissionId} {
      allow list:   if isAdmin();
      allow get:    if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── Admin Notifications ──────────────────────────────────────────────────
    // Visible only to admins. Users cannot read or write these.
    match /admin_notifications/{notificationId} {
      allow read, write: if isAdmin();
    }

    // ─── User Profiles ────────────────────────────────────────────────────────
    // Admins can list + read + write all users.
    // Users can only read/write their own profile and subcollections.
    match /users/{userId} {
      allow list:  if isAdmin();
      allow get:   if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();

      // Subcollections: wallets, transactions, balances, etc.
      match /{allSubcollections=**} {
        allow read:  if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // ─── Prices / Market Data ─────────────────────────────────────────────────
    // Read-only, publicly accessible (used for live price display).
    match /prices/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Email Logs / Notification Logs ───────────────────────────────────────
    // Admin-only audit trail.
    match /email_logs/{docId} {
      allow read, write: if isAdmin();
    }

    match /notification_logs/{docId} {
      allow read, write: if isAdmin();
    }

  }
}
