
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    /**
     * @description Collection Group Rules for Background Ledger Verification.
     */
    match /{path=**}/wallets/{walletId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{path=**}/transactions/{transactionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Global Protocol Settings
     */
    match /protocol_settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn(); // In production, restrict to specific Admin UID
    }

    /**
     * @description Hierarchical rules for user-specific data.
     */
    match /users/{userId} {
      allow read: if true; 
      allow write: if isOwner(userId);

      match /wallets/{walletId} {
        allow read: if true;
        allow write: if isOwner(userId);

        match /transactions/{transactionId} {
          allow read: if true;
          allow write: if isOwner(userId);
        }
      }

      match /price_alerts/{alertId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
